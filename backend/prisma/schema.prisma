generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  alerts    Alert[]
  reviews   Review[]
}

model Product {
  id           String       @id @default(cuid())
  name         String @unique
  description  String?
  brand        String?
  imageUrl     String?
  category     String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  pricePoints  PricePoint[]
  reviews      Review[]
  alerts       Alert[]
}

model PricePoint {
  id          String   @id @default(cuid())
  productId   String
  platform    String   // e.g., 'Amazon', 'Flipkart'
  price       Float
  original    Float?
  url         String
  inStock     Boolean  @default(true)
  seller      String?
  timestamp   DateTime @default(now())
  product     Product  @relation(fields: [productId], references: [id])

  @@index([productId, platform, timestamp])
}

model Alert {
  id          String   @id @default(cuid())
  userId      String
  productId   String
  targetPrice Float
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])
}

model Review {
  id          String   @id @default(cuid())
  userId      String
  productId   String
  rating      Int
  comment     String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])
}
